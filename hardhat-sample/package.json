{
  "name": "flare-hardhat-sample",
  "version": "1.0.0",
  "description": "Flare Network Hardhat 3 チュートリアルプロジェクト",
  "type": "module",
  "scripts": {
    "build": "hardhat build",
    "test": "hardhat test",
    "test:solidity": "hardhat test solidity",
    "test:node": "hardhat test nodejs",
    "node": "hardhat node",
    "deploy:local": "hardhat ignition deploy ignition/modules/Counter.ts",
    "deploy:coston2": "hardhat ignition deploy ignition/modules/Counter.ts --network coston2",
    "deploy:songbird": "hardhat ignition deploy ignition/modules/Counter.ts --network songbird",
    "counter:get": "hardhat counter:get --network coston2",
    "counter:increment": "hardhat counter:increment --network coston2",
    "counter:increment-by": "hardhat counter:increment-by --network coston2",
    "counter:decrement": "hardhat counter:decrement --network coston2",
    "counter:reset": "hardhat counter:reset --network coston2",
    "counter:info": "hardhat counter:info --network coston2",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.0.0",
    "@nomicfoundation/hardhat-ignition-viem": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
    "@nomicfoundation/hardhat-viem": "^3.0.0",
    "@nomicfoundation/hardhat-viem-assertions": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.0",
    "@types/node": "^22.0.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.7",
    "hardhat": "^3.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-solidity": "^1.4.0",
    "typescript": "^5.0.0",
    "viem": "^2.43.0"
  }
}
