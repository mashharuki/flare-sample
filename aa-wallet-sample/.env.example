# ============================================================
# Flare Smart Accounts — 環境変数テンプレート
# cp .env.example .env して値を設定してください
# ============================================================

# XRPL テストネット用ウォレットシード (Coston2 用)
# XRP テストネット faucet: https://xrpl.org/resources/dev-tools/xrp-faucets
XRPL_SEED=s...

# Flare Coston2 RPC URL (省略時はデフォルトを使用)
# デフォルト: https://coston2-api.flare.network/ext/C/rpc
FLARE_RPC_URL=

# スクリプト 04, 05 用: Flare ウォレット秘密鍵
# カスタム命令の登録・実行に必要
PRIVATE_KEY=0x...

# スクリプト 04 用: FXRP の転送先 Flare アドレス
RECIPIENT_ADDRESS=0x...
